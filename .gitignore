# Secrets
.env

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Agent-generated artifacts (scripts, cleaned data, dashboards, sqlite dbs).
# We keep the folder but ignore its contents so each run starts fresh.
workspace/*
!workspace/.gitkeep

# Streamlit
.streamlit/

# Article authoring artifacts — prose + cover images are kept local (e.g. published to
# Medium), not version-controlled. The runnable code/ snapshots stay tracked.
articles/00-index.md
articles/*/article.md
articles/*/cover.png
articles/*/cover.svg

# READMEs — revisit later (unanchored: every README.md at any level, incl. code/ snapshots)
README.md
