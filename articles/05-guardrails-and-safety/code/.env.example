# Copy this file to `.env` and fill in your key.
#   cp .env.example .env

# Required: your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# The model the agents reason with. "gpt-5" is the most capable current default.
# If your account does not yet have gpt-5 access, set this to gpt-4.1.
OPENAI_MODEL=gpt-5

# A smaller / cheaper model used only for the fast input guardrail classifier.
# Set to gpt-4.1-mini if you don't have gpt-5-mini access.
OPENAI_GUARDRAIL_MODEL=gpt-5-mini

# Embedding model used to build the RAG knowledge index (`python -m data_agent.ingest`).
OPENAI_EMBED_MODEL=text-embedding-3-small

# Optional: turn off tracing if you don't want runs sent to the OpenAI Traces dashboard.
# OPENAI_AGENTS_DISABLE_TRACING=1
